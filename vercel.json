{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    },
    {
      "src": "**/*.html",
      "use": "@vercel/static"
    },
    {
      "src": "**/*.css",
      "use": "@vercel/static"
    },
    {
      "src": "dashboard_designer/**/*.js",
      "use": "@vercel/static"
    },
    {
      "src": "dashboard_eo/**/*.js",
      "use": "@vercel/static"
    },
    {
      "src": "foto/**/*",
      "use": "@vercel/static"
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/server.js"
    },
    {
      "source": "/",
      "destination": "/home/home.html"
    }
  ]
}